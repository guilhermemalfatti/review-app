# Leave empty for local `npm run dev` (Vite proxies /api → localhost:8080).
# On GitHub Pages builds, set to the Render API origin (no trailing slash).
VITE_API_URL=

# Local default is /. Project Pages needs /review-app/
VITE_BASE_PATH=/

# Optional override for the Vite proxy target
# VITE_API_PROXY=http://localhost:8080
